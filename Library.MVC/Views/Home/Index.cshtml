@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to Community Library Desk</h1>
    <p>A simple system to track books, members, and loans.</p>
    
    <div class="row mt-5">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Books</h5>
                    <p class="card-text">Manage library catalog, search and filter books by category and availability.</p>
                    <a asp-controller="Books" asp-action="Index" class="btn btn-primary">Browse Books</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Members</h5>
                    <p class="card-text">Keep track of library members, their contact info and loan history.</p>
                    <a asp-controller="Members" asp-action="Index" class="btn btn-primary">View Members</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Loans</h5>
                    <p class="card-text">Lend books to members, track due dates and manage returns.</p>
                    <a asp-controller="Loans" asp-action="Index" class="btn btn-primary">Manage Loans</a>
                </div>
            </div>
        </div>
    </div>
</div>
